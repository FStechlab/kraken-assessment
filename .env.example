# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with repo scope (read + write access to target repos)
# Required permissions: repo (full), workflow
GITHUB_TOKEN=ghp_your_token_here

# ── Groq ──────────────────────────────────────────────────────────────────────
# Free API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Model to use for test generation.
# Recommended free options: llama-3.3-70b-versatile, llama-3.1-8b-instant, deepseek-r1-distill-llama-70b
GROQ_MODEL=llama-3.3-70b-versatile

# ── Persistence ───────────────────────────────────────────────────────────────
# Relative path for the SQLite database file (directory is auto-created)
SQLITE_DATABASE_PATH=data/coverage.db

# ── Git Commit Identity ───────────────────────────────────────────────────────
GIT_USER_NAME=ts-coverage-bot
GIT_USER_EMAIL=bot@ts-coverage-improver.local
